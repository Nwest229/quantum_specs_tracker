    "braket": {
      "enabled": true,
      "emit_skips": true,
      "device_arns": [],
      "_note": "`pip install amazon-braket-sdk` + AWS creds. Auto-discovers IonQ, Rigetti, IQM, QuEra device docs incl. live fidelities; supersedes their cited-const entries when live."
    }
  },
